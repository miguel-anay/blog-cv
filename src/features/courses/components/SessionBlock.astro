---
import type { CourseSession } from '../../../lib/api-types';

export interface Props {
  session: CourseSession;
}

const { session } = Astro.props;

function getVideoEmbed(url: string): string | null {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  if (yt) return `https://www.youtube-nocookie.com/embed/${yt[1]}`;
  const vimeo = url.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  return null;
}

const embedUrl = session.video ? getVideoEmbed(session.video.url) : null;

const badge = (type: string) =>
  type === 'github' ? 'gh' : type === 'video' ? '▶' : '↗';
---

<div class="session-block" id={session.anchorId}>
  <div class="session-block__header">
    <span class="session-block__num">{String(session.number).padStart(2, '0')}</span>
    <h2 class="session-block__title">{session.title}</h2>
  </div>

  {embedUrl && (
    <div class="session-block__embed">
      <iframe
        src={embedUrl}
        title={session.video!.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    </div>
  )}

  {session.video && !embedUrl && (
    <a href={session.video.url} target="_blank" rel="noopener noreferrer" class="session-block__video-link">
      <span class={`session-block__badge session-block__badge--video`}>▶</span>
      {session.video.title}
    </a>
  )}

  {session.materials.length > 0 && (
    <details class="session-materials">
      <summary class="session-materials__toggle">
        <span class="session-materials__prompt">$</span>
        <span>material</span>
        <span class="session-materials__count">{session.materials.length}</span>
      </summary>
      <div class="session-materials__list">
        {session.materials.map((m) => (
          <a href={m.url} target="_blank" rel="noopener noreferrer" class="session-materials__item">
            <span class={`session-block__badge session-block__badge--${m.type}`}>{badge(m.type)}</span>
            <span class="session-materials__label">{m.title}</span>
          </a>
        ))}
      </div>
    </details>
  )}
</div>

<style>
  .session-block {
    padding: 40px 0 48px;
    border-bottom: 1px dashed var(--border);
    scroll-margin-top: 100px;
  }
  .session-block:last-child { border-bottom: none; }

  .session-block__header {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 24px;
  }

  .session-block__num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    flex-shrink: 0;
  }

  .session-block__title {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.3;
  }

  .session-block__embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: 6px;
    overflow: hidden;
    background: #000;
    margin-bottom: 20px;
  }
  .session-block__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .session-block__video-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-raised);
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    margin-bottom: 20px;
  }
  .session-block__video-link:hover { color: var(--accent); }

  /* Accordion */
  .session-materials {
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-raised);
    overflow: hidden;
  }

  .session-materials__toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    list-style: none;
    user-select: none;
  }
  .session-materials__toggle::-webkit-details-marker { display: none; }
  .session-materials__toggle::before {
    content: '▶';
    font-size: 8px;
    color: var(--accent);
    transition: transform 0.15s;
  }
  details[open] .session-materials__toggle::before {
    transform: rotate(90deg);
  }
  .session-materials__prompt { color: var(--accent); }
  .session-materials__count {
    background: var(--bg-overlay);
    color: var(--text-dim);
    padding: 1px 6px;
    border-radius: 8px;
    font-size: 10px;
  }

  .session-materials__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 4px 0 8px;
    border-top: 1px solid var(--border);
  }

  .session-materials__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    text-decoration: none;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    transition: color 0.12s, background 0.12s;
  }
  .session-materials__item:hover {
    color: var(--text);
    background: var(--bg-overlay);
  }
  .session-materials__label { flex: 1; }

  /* Badges */
  .session-block__badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .session-block__badge--github {
    background: rgba(139, 148, 158, 0.15);
    color: #8b949e;
    border: 1px solid rgba(139, 148, 158, 0.25);
  }
  .session-block__badge--video {
    background: rgba(248, 81, 73, 0.12);
    color: #f85149;
    border: 1px solid rgba(248, 81, 73, 0.2);
  }
  .session-block__badge--link {
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(124, 240, 140, 0.2);
  }

  @media (max-width: 767px) {
    .session-block { scroll-margin-top: 60px; }
    .session-block__title { font-size: 17px; }
  }
</style>
