---
import type { CourseResource } from '../../../lib/api-types';

export interface Props {
  resource: CourseResource;
}

const { resource } = Astro.props;

function getVideoEmbed(url: string): string | null {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  if (yt) return `https://www.youtube-nocookie.com/embed/${yt[1]}`;
  const vimeo = url.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  return null;
}

const embedUrl = resource.type === 'video' ? getVideoEmbed(resource.url) : null;

const badge = resource.type === 'github' ? 'gh' : resource.type === 'video' ? '▶' : '↗';
---

<div class="resource">
  {embedUrl && (
    <div class="resource__embed">
      <iframe
        src={embedUrl}
        title={resource.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    </div>
  )}
  <div class="resource__row">
    <span class={`resource__badge resource__badge--${resource.type}`}>{badge}</span>
    <div class="resource__info">
      <a href={resource.url} target="_blank" rel="noopener noreferrer" class="resource__title">
        {resource.title}
      </a>
      {resource.description && <p class="resource__desc">{resource.description}</p>}
    </div>
  </div>
</div>

<style>
  .resource {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-raised);
  }

  .resource__embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: 3px;
    overflow: hidden;
    background: #000;
  }
  .resource__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .resource__row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .resource__badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    padding: 3px 7px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .resource__badge--github {
    background: rgba(139, 148, 158, 0.15);
    color: #8b949e;
    border: 1px solid rgba(139, 148, 158, 0.25);
  }
  .resource__badge--video {
    background: rgba(248, 81, 73, 0.12);
    color: #f85149;
    border: 1px solid rgba(248, 81, 73, 0.2);
  }
  .resource__badge--link {
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(124, 240, 140, 0.2);
  }

  .resource__info { display: flex; flex-direction: column; gap: 4px; }

  .resource__title {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    text-decoration: none;
    line-height: 1.4;
  }
  .resource__title:hover { color: var(--accent); }

  .resource__desc {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
