---
export interface Props {
  title: string;
  description?: string | null;
  resourceCount: number;
  href: string;
  index?: number;
}

const { title, description, resourceCount, href, index } = Astro.props;
const num = index != null ? String(index).padStart(2, '0') : '';
---

<a href={href} class="section-card">
  <div class="section-card__top">
    {num && <span class="section-card__num">{num}</span>}
    <span class="section-card__count">
      {resourceCount} {resourceCount === 1 ? 'recurso' : 'recursos'}
    </span>
  </div>
  <h3 class="section-card__title">{title}</h3>
  {description && <p class="section-card__desc">{description}</p>}
</a>

<style>
  .section-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s, border-color 0.12s;
  }
  .section-card:hover {
    background: var(--bg-raised);
    border-color: var(--accent);
  }

  .section-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .section-card__num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    font-weight: 600;
  }

  .section-card__count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .section-card__title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.015em;
  }
  .section-card:hover .section-card__title { color: var(--accent); }

  .section-card__desc {
    font-size: 14px;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }
</style>
