---
import type { CourseSection, CourseSession } from '../../../lib/api-types';

export interface Props {
  sections: CourseSection[];
  activeSectionId?: number | null;
  isDiplomado?: boolean;
  sessions?: CourseSession[];
}

const { sections, activeSectionId = null, isDiplomado = false, sessions = [] } = Astro.props;

const showSessions = isDiplomado && sessions.length > 0;
---

<nav
  class="course-nav"
  aria-label={isDiplomado ? 'Semanas del diplomado' : 'Secciones del curso'}
  data-mode={isDiplomado ? 'diplomado' : 'course'}
>
  <div class="course-nav__label">
    <span class="course-nav__prompt">#</span>
    <span>{showSessions ? 'sesiones' : isDiplomado ? 'semanas' : 'secciones'}</span>
  </div>

  {showSessions ? (
    <ol class="course-nav__list">
      {sessions.map((session) => (
        <li>
          <a
            href={`#${session.anchorId}`}
            class="course-nav__item"
            data-section={session.anchorId}
          >
            <span class="course-nav__num">{String(session.number).padStart(2, '0')}</span>
            <span class="course-nav__title">{session.title}</span>
          </a>
        </li>
      ))}
    </ol>
  ) : (
    <ol class="course-nav__list">
      {sections.map((section, i) => (
        <li>
          <a
            href={isDiplomado ? `?section=${section.id}` : `#section-${section.id}`}
            class:list={[
              'course-nav__item',
              isDiplomado
                ? activeSectionId === section.id && 'is-active'
                : false,
            ]}
            data-section={`section-${section.id}`}
          >
            <span class="course-nav__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="course-nav__title">
              {isDiplomado ? `Semana ${section.order}` : section.title}
            </span>
            {section.resources.length > 0 && (
              <span class="course-nav__badge">{section.resources.length}</span>
            )}
          </a>
        </li>
      ))}
    </ol>
  )}
</nav>

<script>
  const nav = document.querySelector<HTMLElement>('.course-nav');
  const mode = nav?.dataset.mode;

  if (mode === 'course') {
    const navItems = document.querySelectorAll<HTMLAnchorElement>('.course-nav__item');
    const sections = document.querySelectorAll<HTMLElement>('.course-section');

    if (navItems.length && sections.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const id = entry.target.id;
            navItems.forEach((a) => {
              a.classList.toggle('is-active', a.dataset.section === id);
            });
          }
        },
        { rootMargin: '-20% 0px -70% 0px', threshold: 0 },
      );
      sections.forEach((s) => observer.observe(s));
    }
  } else if (mode === 'diplomado') {
    const navItems = document.querySelectorAll<HTMLAnchorElement>(
      '.course-nav__item[data-section^="session-"]',
    );
    const blocks = document.querySelectorAll<HTMLElement>('.session-block[id^="session-"]');

    if (navItems.length && blocks.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const id = entry.target.id;
            navItems.forEach((a) => {
              a.classList.toggle('is-active', a.dataset.section === id);
            });
          }
        },
        { rootMargin: '-10% 0px -80% 0px', threshold: 0 },
      );
      blocks.forEach((b) => observer.observe(b));
    }
  }
</script>

<style>
  .course-nav {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .course-nav__label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .course-nav__prompt { color: var(--accent); }

  .course-nav__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .course-nav__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 4px;
    text-decoration: none;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.4;
    transition: color 0.12s, background 0.12s;
    border-left: 2px solid transparent;
  }
  .course-nav__item:hover {
    color: var(--text);
    background: var(--bg-raised);
  }
  .course-nav__item.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
    background: var(--accent-soft);
  }

  .course-nav__num {
    color: var(--text-faint);
    flex-shrink: 0;
    font-size: 10px;
  }
  .course-nav__item.is-active .course-nav__num { color: var(--accent); }

  .course-nav__title { flex: 1; }

  .course-nav__badge {
    font-size: 10px;
    background: var(--bg-overlay);
    color: var(--text-dim);
    padding: 1px 5px;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .course-nav__item.is-active .course-nav__badge {
    background: rgba(124, 240, 140, 0.15);
    color: var(--accent);
  }

  /* Mobile */
  @media (max-width: 767px) {
    /* Diplomado: vertical sticky nav */
    .course-nav[data-mode="diplomado"] {
      position: sticky;
      top: 0;
      z-index: 50;
      max-height: 50vh;
      overflow-y: auto;
      flex-direction: column;
      background: var(--bg-raised);
      border-bottom: 1px solid var(--border);
      border-radius: 0;
      gap: 4px;
    }

    .course-nav[data-mode="diplomado"] .course-nav__list {
      flex-direction: column;
      overflow-x: visible;
    }

    .course-nav[data-mode="diplomado"] .course-nav__item {
      white-space: normal;
      border-left: 2px solid transparent;
      border-bottom: none;
      border-radius: 4px;
    }

    /* Regular course: compact vertical list */
    .course-nav[data-mode="course"] {
      max-height: 50vh;
      overflow-y: auto;
    }
  }
</style>
