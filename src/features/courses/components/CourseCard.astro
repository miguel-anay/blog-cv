---
export interface Props {
  title: string;
  description: string;
  slug: string;
  level: string;
  sectionCount: number;
  index?: number;
}

const { title, description, slug, level, sectionCount, index } = Astro.props;
const num = index != null ? `0x${index.toString(16).padStart(2, '0')}` : '';

const levelLabel: Record<string, string> = {
  beginner: 'principiante',
  intermediate: 'intermedio',
  advanced: 'avanzado',
};
---

<a href={`/courses/${slug}/`} class="course-card">
  <div class="course-card__num">{num}</div>
  <div class="course-card__body">
    <div class="course-card__meta">
      <span class="course-card__level">{levelLabel[level] ?? level}</span>
      <span class="course-card__sep">·</span>
      <span>{sectionCount} {sectionCount === 1 ? 'sección' : 'secciones'}</span>
    </div>
    <h3 class="course-card__title">{title}</h3>
    <p class="course-card__desc">{description}</p>
  </div>
  <div class="course-card__arrow" aria-hidden="true">›</div>
</a>

<style>
  .course-card {
    display: grid;
    grid-template-columns: 52px 1fr 28px;
    align-items: start;
    gap: 20px;
    padding: 28px 0;
    border-bottom: 1px dashed var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }
  .course-card:hover { background: var(--bg-raised); margin: 0 calc(var(--pad-x) * -1); padding-left: var(--pad-x); padding-right: var(--pad-x); }
  .course-card:last-child { border-bottom: none; }

  .course-card__num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    padding-top: 6px;
    text-align: right;
  }

  .course-card__body { display: flex; flex-direction: column; gap: 8px; }

  .course-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  .course-card__level { color: var(--accent); }
  .course-card__sep { color: var(--text-faint); }

  .course-card__title {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .course-card:hover .course-card__title { color: var(--accent); }

  .course-card__desc {
    font-size: 14px;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
    max-width: 680px;
  }

  .course-card__arrow {
    font-size: 22px;
    color: var(--text-faint);
    padding-top: 4px;
    transition: color 0.12s, transform 0.12s;
  }
  .course-card:hover .course-card__arrow { color: var(--accent); transform: translateX(3px); }
</style>
