---
export interface Props {
  title: string;
  description: string;
  slug: string;
  level: string;
  sectionCount: number;
  index?: number;
  type: 'course' | 'diplomado';
}

const { title, description, slug, level, sectionCount, index, type } = Astro.props;
const num = index != null ? `0x${index.toString(16).padStart(2, '0')}` : '';
const href = type === 'diplomado' ? `/courses/${slug}/sections/` : `/courses/${slug}/`;

const levelLabel: Record<string, string> = {
  beginner: 'principiante',
  intermediate: 'intermedio',
  advanced: 'avanzado',
};
---

<a href={href} class="course-card">
  <div class="course-card__top">
    <span class="course-card__num">{num}</span>
    <div class="course-card__meta">
      <span class="course-card__level">{levelLabel[level] ?? level}</span>
      <span class="course-card__sep">·</span>
      <span class="course-card__sections">{sectionCount} {sectionCount === 1 ? 'sección' : 'secciones'}</span>
      {type === 'diplomado' && <span class="course-card__type-badge">diplomado</span>}
    </div>
  </div>
  <h3 class="course-card__title">{title}</h3>
  <p class="course-card__desc">{description}</p>
</a>

<style>
  .course-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s, border-color 0.12s;
  }
  .course-card:hover {
    background: var(--bg-raised);
    border-color: var(--accent);
  }

  .course-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .course-card__num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
  }

  .course-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  .course-card__level { color: var(--accent); }
  .course-card__sep { color: var(--text-faint); }

  .course-card__type-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 3px;
    padding: 1px 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .course-card__title {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .course-card:hover .course-card__title { color: var(--accent); }

  .course-card__desc {
    font-size: 14px;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }
</style>
