---
// One question rendered per instance; all N questions are rendered server-side
// up front (per design) and shown/hidden by attempt-controller.ts (Phase 4) via
// the `hidden` attribute — no per-question fetch. This component only owns the
// initial visibility (`initiallyVisible`, defaults to hidden) and static markup;
// the controller decides which one is visible at any given time.

export interface QuestionOption {
  id: number;
  text: string;
}

export interface Props {
  questionId: number;
  index: number;
  prompt: string;
  options: QuestionOption[];
  selectedOptionId?: number | null;
  total: number;
  initiallyVisible?: boolean;
}

const {
  questionId,
  index,
  prompt,
  options,
  selectedOptionId = null,
  total,
  initiallyVisible = false,
} = Astro.props;

const groupName = `question-${questionId}`;
const promptId = `question-${questionId}-prompt`;
---

<article
  class="question-card"
  data-question-card
  data-question-id={questionId}
  data-question-index={index}
  hidden={!initiallyVisible}
>
  <p class="question-card__meta">Pregunta {index} de {total}</p>
  <h2 class="question-card__prompt" id={promptId}>{prompt}</h2>
  <fieldset class="question-card__options" aria-labelledby={promptId}>
    {options.map((option) => (
      <label class="question-card__option">
        <input
          type="radio"
          name={groupName}
          value={option.id}
          checked={selectedOptionId === option.id}
          data-option-id={option.id}
        />
        <span>{option.text}</span>
      </label>
    ))}
  </fieldset>
</article>

<style>
  .question-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .question-card__meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    margin: 0;
  }

  .question-card__prompt {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .question-card__options {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 0;
    padding: 0;
    margin: 0;
  }

  .question-card__option {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-raised);
    color: var(--text);
    font-size: 15px;
    line-height: 1.5;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
  }

  .question-card__option:hover {
    border-color: var(--accent);
  }

  .question-card__option:has(input:checked) {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .question-card__option input {
    margin-top: 3px;
    accent-color: var(--accent);
    flex-shrink: 0;
  }
</style>
