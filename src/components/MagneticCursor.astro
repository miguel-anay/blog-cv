<div class="cursor-dot" aria-hidden="true"></div><div class="cursor-ring" aria-hidden="true"></div>

<script>
  import gsap from "gsap";

  const dot = document.querySelector<HTMLElement>(".cursor-dot");
  const ring = document.querySelector<HTMLElement>(".cursor-ring");

  // Exit early on coarse-pointer (touch) devices — no custom cursor needed.
  if (!window.matchMedia("(pointer: fine)").matches) {
    dot?.remove();
    ring?.remove();
  } else if (dot && ring) {
    // Activate cursor: set class so CSS switches native cursor off
    document.body.classList.add("cursor-on");

    const mm = gsap.matchMedia();

    mm.add({ ok: "(prefers-reduced-motion: no-preference)" }, () => {
      // quickTo for smooth, performant mouse-following
      const dotX = gsap.quickTo(dot, "x", { duration: 0.15, ease: "power3" });
      const dotY = gsap.quickTo(dot, "y", { duration: 0.15, ease: "power3" });
      const ringX = gsap.quickTo(ring, "x", { duration: 0.45, ease: "power3" });
      const ringY = gsap.quickTo(ring, "y", { duration: 0.45, ease: "power3" });

      // Single pointermove handler for both elements
      document.addEventListener("pointermove", (e: PointerEvent) => {
        dotX(e.clientX);
        dotY(e.clientY);
        ringX(e.clientX);
        ringY(e.clientY);
      });

      // Scale ring on interactive elements
      const hoverTargets = document.querySelectorAll<HTMLElement>(
        "a, button, [data-magnetic]"
      );

      hoverTargets.forEach((el) => {
        el.addEventListener("mouseenter", () => {
          gsap.to(ring, { scale: 1.8, duration: 0.25, ease: "power2.out" });
        });
        el.addEventListener("mouseleave", () => {
          gsap.to(ring, { scale: 1, duration: 0.25, ease: "power2.out" });
        });
      });

      // Cleanup: called when matchMedia condition no longer matches
      return () => {
        gsap.set(dot, { clearProps: "all" });
        gsap.set(ring, { clearProps: "all" });
      };
    });
  }
</script>
