---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/seo/BaseHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MagneticCursor from "../components/MagneticCursor.astro";
import "../styles/prose.css";

type Props =
  | (CollectionEntry<"blog">["data"] & {
      readMin?: number;
      categorySlug?: string;
      categoryName?: string;
      author?: { name: string; initials: string; meta?: string };
      prev?: { slug: string; title: string };
      next?: { slug: string; title: string };
      slug?: string;
    });

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  readMin = 6,
  categorySlug,
  categoryName,
  author = { name: "Miguel Anay", initials: "MA", meta: "ingeniero · Lima, PE · @miguel-anay" },
  prev,
  next,
  slug,
} = Astro.props;

const fmt = (d: Date | string | undefined) =>
  d ? new Date(d).toLocaleDateString("es-PE", { year: "numeric", month: "2-digit", day: "2-digit" }) : "—";

const slugNoExt = slug ?? title.toLowerCase().replace(/\s+/g, "-");
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description ?? undefined} image={heroImage as string | undefined} />
  </head>
  <body>
    <MagneticCursor />
    <Header />

    <article class="article-shell">
      <!-- ── Article header ─────────────────────────────── -->
      <section class="article-header">
        <div class="article-header__inner">
          <nav class="article-crumb" aria-label="ruta">
            <a href="/">./</a>
            <span class="article-crumb__sep">/</span>
            <a href="/blog">blog</a>
            {categorySlug && (
              <>
                <span class="article-crumb__sep">/</span>
                <a href={`/blog/category/${categorySlug}`} class="article-crumb__cat">{categorySlug}</a>
              </>
            )}
            <span class="article-crumb__sep">/</span>
            <span class="article-crumb__active">{slugNoExt}.md</span>
          </nav>

          <div class="article-frontmatter">
            <span class="article-frontmatter__delim">---</span>
            <div class="article-frontmatter__line">
              <span class="article-frontmatter__key">title</span>
              <span class="article-frontmatter__colon">:</span>
              <span class="article-frontmatter__val">"{title}"</span>
            </div>
            {categorySlug && (
              <div class="article-frontmatter__line">
                <span class="article-frontmatter__key">category</span>
                <span class="article-frontmatter__colon">:</span>
                <span class="article-frontmatter__val">{categorySlug}</span>
              </div>
            )}
            <div class="article-frontmatter__line">
              <span class="article-frontmatter__key">published</span>
              <span class="article-frontmatter__colon">:</span>
              <span class="article-frontmatter__val">{fmt(pubDate)}</span>
            </div>
            {updatedDate && (
              <div class="article-frontmatter__line">
                <span class="article-frontmatter__key">updated</span>
                <span class="article-frontmatter__colon">:</span>
                <span class="article-frontmatter__val">{fmt(updatedDate)}</span>
              </div>
            )}
            <div class="article-frontmatter__line">
              <span class="article-frontmatter__key">read</span>
              <span class="article-frontmatter__colon">:</span>
              <span class="article-frontmatter__val">{readMin} min</span>
            </div>
            <span class="article-frontmatter__delim">---</span>
          </div>

          <h1 class="article-title">{title}</h1>
          {description && <p class="article-dek">{description}</p>}

          <div class="article-byline">
            <div class="article-author">
              <div class="article-avatar">{author.initials}</div>
              <div>
                <div class="article-author__name">{author.name}</div>
                {author.meta && <div class="article-author__meta">{author.meta}</div>}
              </div>
            </div>
            <div class="article-byline__meta">
              <span>{fmt(pubDate)}</span>
              <span class="article-byline__sep">·</span>
              <span>{readMin} min</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Body: prose + TOC ──────────────────────────── -->
      <section class="article-body">
        <div class="article-body__inner">
          <div class="prose">
            <slot />
          </div>

          <aside class="article-aside">
            <div class="aside-box">
              <div class="aside-box__h">
                <span class="aside-box__h-mark">{`//`}</span> en esta página
              </div>
              <ol class="toc-list" id="toc-list">
                <li>Cargando TOC...</li>
              </ol>
            </div>
            <div class="aside-box">
              <div class="aside-box__h"># compartir</div>
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener" class="aside-box__link">$ tweet</a>
              <a href={Astro.url.toString()} class="aside-box__link" data-copy-url>$ copy url</a>
            </div>
          </aside>
        </div>
      </section>

      <!-- ── Prev / next ────────────────────────────────── -->
      {(prev || next) && (
        <section class="prevnext">
          <div class="prevnext__inner">
            {prev ? (
              <a href={`/blog/${prev.slug}/`} class="prevnext__card">
                <span class="prevnext__label">← prev</span>
                <span class="prevnext__title">{prev.title}</span>
              </a>
            ) : <span></span>}
            {next ? (
              <a href={`/blog/${next.slug}/`} class="prevnext__card prevnext__card--next">
                <span class="prevnext__label">next →</span>
                <span class="prevnext__title">{next.title}</span>
              </a>
            ) : <span></span>}
          </div>
        </section>
      )}
    </article>

    <Footer />

    <style>
      .article-crumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 36px;
        flex-wrap: wrap;
      }
      .article-crumb a { color: var(--text-muted); }
      .article-crumb__cat { color: var(--accent); }
      .article-crumb__sep { color: var(--text-faint); }
      .article-crumb__active { color: var(--text); }
      .aside-box__link {
        display: block;
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--text);
        padding: 5px 0;
      }
      .aside-box__link:hover { color: var(--accent); }

      @media (max-width: 767px) {
        .article-aside { display: none; }
      }
    </style>

    <!-- TOC builder + copy-url -->
    <script>
      (function () {
        const list = document.getElementById("toc-list");
        const prose = document.querySelector(".prose");
        if (list && prose) {
          const headings = prose.querySelectorAll("h2, h3");
          if (headings.length === 0) {
            list.innerHTML = '<li style="color: var(--text-dim)">(sin secciones)</li>';
          } else {
            list.innerHTML = "";
            headings.forEach((h, i) => {
              if (!h.id) {
                h.id = (h.textContent || `s-${i}`)
                  .toLowerCase()
                  .replace(/[^a-z0-9]+/g, "-")
                  .replace(/^-|-$/g, "");
              }
              const li = document.createElement("li");
              li.innerHTML = `<a href="#${h.id}" style="color: inherit; text-decoration: none">${h.textContent}</a>`;
              if (h.tagName === "H3") li.style.paddingLeft = "12px";
              list.appendChild(li);
            });
          }
        }

        document.querySelectorAll("[data-copy-url]").forEach((el) => {
          el.addEventListener("click", (e) => {
            e.preventDefault();
            const url = (el as HTMLAnchorElement).href;
            navigator.clipboard.writeText(url).then(() => {
              const orig = el.textContent;
              el.textContent = "✓ copiado";
              setTimeout(() => { el.textContent = orig; }, 1500);
            });
          });
        });
      })();
    </script>
  </body>
</html>
