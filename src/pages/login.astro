---
import BaseHead from '../components/seo/BaseHead.astro';
import { auth } from '../lib/auth';

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (session) return Astro.redirect('/courses');

const redirect = Astro.url.searchParams.get('redirect') ?? '/courses';
const errorParam = Astro.url.searchParams.get('error');
const showMagicLinkError = errorParam === 'magic-link';
---
<!doctype html>
<html lang="es">
  <head>
    <BaseHead title="Iniciar sesión — Miguel Anay" description="Accedé a los cursos" />
  </head>
  <body>
    <main class="login-page">
      <div class="login-card">
        <div class="login-brand">
          <span class="login-brand__dot">#</span>
          <span class="login-brand__name">miguel-anay</span>
        </div>

        <h1 class="login-title">Acceder a los cursos</h1>
        <p class="login-subtitle">Iniciá sesión para ver el contenido</p>

        {showMagicLinkError && (
          <div class="magic-error-banner" role="alert" id="error-banner">
            <p>El link expiró o ya fue usado. Solicitá uno nuevo.</p>
          </div>
        )}

        <button id="btn-google" class="btn-google">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continuar con Google
        </button>

        <div class="divider" aria-hidden="true">
          <span>o</span>
        </div>

        <form id="form-magic" class="magic-form" novalidate>
          <div class="field">
            <label for="ml-email" class="field-label">Accedé con tu email</label>
            <input
              type="email"
              id="ml-email"
              name="email"
              class="field-input"
              placeholder="tu@email.com"
              autocomplete="email"
              required
            />
          </div>
          <button type="submit" id="btn-magic" class="btn-magic">
            Enviar enlace de acceso
          </button>
          <div id="magic-send-error" class="magic-inline-error" hidden>
            No pudimos enviar el email. Intentá de nuevo.
          </div>
        </form>

        <div id="magic-confirm" class="magic-confirm" hidden>
          <p>Revisá tu email — te enviamos un link de acceso a <strong id="magic-confirm-email"></strong>.</p>
        </div>
      </div>
    </main>

    <script define:vars={{ redirect }}>
      // Google OAuth
      document.getElementById('btn-google').addEventListener('click', async () => {
        const btn = document.getElementById('btn-google');
        btn.disabled = true;
        btn.textContent = 'Redirigiendo...';
        try {
          const res = await fetch('/api/auth/sign-in/social', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ provider: 'google', callbackURL: redirect }),
          });
          const data = await res.json();
          if (data.url) window.location.href = data.url;
        } catch {
          btn.disabled = false;
          btn.textContent = 'Continuar con Google';
        }
      });

      // Magic link form
      document.getElementById('form-magic').addEventListener('submit', async (e) => {
        e.preventDefault();

        const emailInput = /** @type {HTMLInputElement} */ (document.getElementById('ml-email'));
        const btnMagic = document.getElementById('btn-magic');
        const sendError = document.getElementById('magic-send-error');
        const confirmBlock = document.getElementById('magic-confirm');
        const confirmEmail = document.getElementById('magic-confirm-email');
        const form = document.getElementById('form-magic');

        const email = emailInput.value.trim().toLowerCase();
        if (!email) {
          emailInput.focus();
          return;
        }

        btnMagic.disabled = true;
        btnMagic.textContent = 'Enviando...';
        sendError.hidden = true;

        try {
          const res = await fetch('/api/auth/sign-in/magic-link', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, callbackURL: redirect }),
          });

          if (res.ok) {
            form.hidden = true;
            confirmEmail.textContent = email;
            confirmBlock.hidden = false;
          } else {
            throw new Error('non-ok response');
          }
        } catch {
          btnMagic.disabled = false;
          btnMagic.textContent = 'Enviar enlace de acceso';
          sendError.hidden = false;
        }
      });
    </script>

    <style>
      .login-page {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px var(--pad-x);
        background: var(--bg);
      }

      .login-card {
        width: 100%;
        max-width: 360px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        padding: 48px 40px;
        background: var(--bg-raised);
        border: 1px solid var(--border);
        border-radius: 8px;
      }

      .login-brand {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 13px;
        margin-bottom: 40px;
      }
      .login-brand__dot { color: var(--accent); font-weight: 700; }
      .login-brand__name { color: var(--text-muted); }

      .login-title {
        font-family: var(--font-sans);
        font-size: 22px;
        font-weight: 700;
        color: var(--text-strong);
        margin: 0 0 8px;
        text-align: center;
        letter-spacing: -0.02em;
      }

      .login-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        margin: 0 0 36px;
        text-align: center;
        line-height: 1.5;
      }

      .btn-google {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 11px 20px;
        background: var(--text-strong);
        color: #111;
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 600;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: opacity 0.15s;
      }
      .btn-google:hover { opacity: 0.9; }
      .btn-google:disabled { opacity: 0.5; cursor: not-allowed; }

      .divider {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        margin: 20px 0 4px;
        color: var(--text-muted);
        font-size: 12px;
      }
      .divider::before,
      .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      .magic-form {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 4px;
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        width: 100%;
      }

      .field-label {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-muted);
      }

      .field-input {
        width: 100%;
        padding: 10px 14px;
        font-size: 14px;
        font-family: var(--font-sans);
        color: var(--text-strong);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        outline: none;
        transition: border-color 0.15s;
        box-sizing: border-box;
      }
      .field-input:focus {
        border-color: var(--accent);
      }

      .btn-magic {
        width: 100%;
        padding: 11px 20px;
        background: transparent;
        color: var(--text-strong);
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 600;
        border: 1px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
      }
      .btn-magic:hover {
        border-color: var(--accent);
        color: var(--accent);
      }
      .btn-magic:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .magic-confirm {
        width: 100%;
        margin-top: 8px;
        padding: 14px;
        background: color-mix(in srgb, var(--accent) 8%, transparent);
        border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
        border-radius: 6px;
        font-size: 13px;
        color: var(--text-strong);
        line-height: 1.5;
        text-align: center;
      }

      .magic-inline-error {
        font-size: 12px;
        color: #e53e3e;
        text-align: center;
      }

      .magic-error-banner {
        width: 100%;
        margin-bottom: 20px;
        padding: 12px 14px;
        background: #fff5f5;
        border: 1px solid #feb2b2;
        border-radius: 6px;
        font-size: 13px;
        color: #c53030;
        line-height: 1.5;
        text-align: center;
      }
      .magic-error-banner p { margin: 0; }

      @media (max-width: 480px) {
        .login-card { padding: 36px 24px; }
      }
    </style>
  </body>
</html>
