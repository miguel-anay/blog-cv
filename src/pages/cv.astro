---
import BaseHead from "../components/seo/BaseHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import CvField from "../components/cv/CvField.astro";
import MagneticCursor from "../components/MagneticCursor.astro";
import { getCv } from "../lib/api";

const cvData = await getCv();

// Fallback if API is unavailable
const personal = cvData?.personal ?? {
  nombre: 'Miguel Anay',
  sitio: 'https://miguel-anay.nom.pe',
  descripcion: 'Software engineer based in Lima, Peru.',
  empresasDestacadas: ['Yiwu Import Corporation'],
  tecnologiasDestacadas: 'TypeScript · Astro · AWS',
  linkedin: 'https://linkedin.com/in/miguelanay',
  anio: String(new Date().getFullYear()),
};
const proyectos = cvData?.proyectos ?? [];
const experiencia = cvData?.experiencia ?? [];
const educacion = cvData?.educacion ?? [];
const cursos = cvData?.cursos ?? [];

// Group cursos by categoria for display
const cursosByCategory = cursos.reduce<Record<string, typeof cursos>>((acc, curso) => {
  if (!acc[curso.categoria]) acc[curso.categoria] = [];
  acc[curso.categoria].push(curso);
  return acc;
}, {});
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={`CV — ${personal.nombre}`}
      description={personal.descripcion ?? ''}
    />
  </head>
  <body>
    <MagneticCursor />
    <Header />

    <main>
      <section class="cv-hero">
        <div class="cv-hero__inner">
          <div class="cv-hero__l">
            <div class="cv-hero__label">$ cat ~/cv.txt --format=full</div>
            <h1 class="cv-name">{personal.nombre}</h1>
            <div class="cv-role">Ingeniero de software · Lima, PE</div>
            <p class="cv-summary">{personal.descripcion}</p>
            <div class="cv-actions">
              <a href="/cv.pdf" class="cv-btn">↓ pdf</a>
              <a href="/cv.json" class="cv-btn">↓ json resume</a>
              {personal.linkedin && (
                <a href={personal.linkedin} target="_blank" rel="noopener" class="cv-btn">linkedin →</a>
              )}
            </div>
          </div>
          <div class="cv-hero__r">
            <div class="cv-term">
              <div class="cv-term__bar">
                <span class="cv-term__dot cv-term__dot--red"></span>
                <span class="cv-term__dot cv-term__dot--yellow"></span>
                <span class="cv-term__dot cv-term__dot--green"></span>
                <span class="cv-term__title">about.json</span>
              </div>
              <div class="cv-term__body">
                <div class="cv-term__prompt">
                  <span class="cv-term__ps1"><span class="cv-term__user">miguel</span><span class="cv-term__at">@</span><span class="cv-term__host">blog</span><span class="cv-term__sep">:</span><span class="cv-term__path">~</span><span class="cv-term__dollar">$</span></span>
                  <span class="cv-term__cmd">cat about.json</span>
                </div>
                <div class="cv-term__output">
                  <div class="cv-term__line"><span class="cv-term__key">email</span><span class="cv-term__val">hola@miguel-anay.nom.pe</span></div>
                  {personal.sitio && <div class="cv-term__line"><span class="cv-term__key">sitio</span><span class="cv-term__val">{personal.sitio}</span></div>}
                  {personal.linkedin && <div class="cv-term__line"><span class="cv-term__key">linkedin</span><span class="cv-term__val">{personal.linkedin.replace(/^https?:\/\//, "")}</span></div>}
                  {personal.empresasDestacadas && personal.empresasDestacadas.length > 0 && (
                    <div class="cv-term__line"><span class="cv-term__key">empresas</span><span class="cv-term__val">{personal.empresasDestacadas.join(" · ")}</span></div>
                  )}
                  {personal.tecnologiasDestacadas && (
                    <div class="cv-term__line"><span class="cv-term__key">stack</span><span class="cv-term__val">{personal.tecnologiasDestacadas}</span></div>
                  )}
                  <div class="cv-term__line cv-term__line--accent"><span class="cv-term__key">status</span><span class="cv-term__val">● disponible — {personal.anio}</span></div>
                </div>
                <div class="cv-term__prompt cv-term__prompt--idle">
                  <span class="cv-term__ps1"><span class="cv-term__user">miguel</span><span class="cv-term__at">@</span><span class="cv-term__host">blog</span><span class="cv-term__sep">:</span><span class="cv-term__path">~</span><span class="cv-term__dollar">$</span></span>
                  <span class="cv-term__cursor"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {experiencia.length > 0 && (
        <section class="section">
          <div class="cv-section-head">
            <span class="section-head__num">§ 01</span>
            <h2 class="section-head__title">experiencia</h2>
          </div>
          <div class="cv-exp-list">
            {experiencia.map((exp) => (
              <div class="cv-exp-item">
                <div class="cv-exp__l">
                  <div class="cv-exp__period">{exp.periodo}</div>
                  {exp.certificado && (
                    <a href={exp.certificado} target="_blank" rel="noopener" class="cv-exp__cert">↗ certificado</a>
                  )}
                </div>
                <div class="cv-exp__r">
                  <div class="cv-exp__role">
                    {exp.cargo}
                    <span class="cv-exp__at">·</span>
                    <span class="cv-exp__company">{exp.empresa}</span>
                  </div>
                  {exp.proyectos && exp.proyectos.length > 0 && (
                    <ul class="cv-exp__bullets">
                      {exp.proyectos.map((p) => (
                        <li>
                          <span class="cv-exp__dash">—</span>
                          <span>
                            <strong>{p.nombre}.</strong> {p.descripcion}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}
                  {exp.tecnologias && exp.tecnologias.length > 0 && (
                    <div class="cv-exp__stack">
                      {exp.tecnologias.map((t) => (
                        <span class="cv-exp__tag">{t.trim()}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {proyectos.length > 0 && (
        <section class="section">
          <div class="cv-section-head">
            <span class="section-head__num">§ 02</span>
            <h2 class="section-head__title">proyectos</h2>
          </div>
          <div class="cv-proj-grid">
            {proyectos.map((p) => (
              <div class="cv-proj-item">
                <div class="cv-proj__inner">
                  <div class="cv-proj__front">
                    <div class="cv-proj__header">
                      <span class="cv-proj__title">{p.titulo}</span>
                      {p.empresa && <span class="cv-proj__co">{p.empresa}</span>}
                    </div>
                    {p.descripcion && <p class="cv-proj__desc">{p.descripcion}</p>}
                    {p.tecnologias && p.tecnologias.length > 0 && (
                      <div class="cv-exp__stack">
                        {p.tecnologias.map((t) => (
                          <span class="cv-exp__tag">{t}</span>
                        ))}
                      </div>
                    )}
                    {p.url && (
                      <a href={p.url} target="_blank" rel="noopener" class="cv-proj__link">↗ {p.url.replace(/^https?:\/\//, '')}</a>
                    )}
                  </div>
                  {p.imagen && (
                    <div class="cv-proj__back">
                      <img src={`/paginas/${p.imagen}`} alt={`Screenshot de ${p.titulo}`} loading="lazy" />
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="section">
        <div class="cv-two-col">
          {educacion.length > 0 && (
            <div>
              <div class="cv-section-head cv-section-head--compact">
                <span class="section-head__num">§ 03</span>
                <h2 class="section-head__title">educación</h2>
              </div>
              <div class="cv-edu">
                {educacion.map((edu) => (
                  <div class="cv-edu-item">
                    <div class="cv-edu__title">{edu.titulo}</div>
                    <div class="cv-edu__place">{edu.institucion}</div>
                    {edu.estado && <div class="cv-edu__estado">{edu.estado}</div>}
                    {edu.certificado && (
                      <a
                        href={edu.certificado}
                        target="_blank"
                        rel="noopener"
                        class="cv-edu__cert"
                      >↗ certificado</a>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          {Object.keys(cursosByCategory).length > 0 && (
            <div>
              <div class="cv-section-head cv-section-head--compact">
                <span class="section-head__num">§ 04</span>
                <h2 class="section-head__title">especializaciones</h2>
              </div>
              <div class="cv-spec">
                {Object.entries(cursosByCategory).map(([cat, items]) => (
                  <details class="cv-spec-item">
                    <summary>
                      <span class="cv-spec__cat">{cat}</span>
                      <span class="cv-spec__count">{items.length} cursos</span>
                    </summary>
                    <ul class="cv-spec__list">
                      {items.map((c) => (
                        <li>
                          <div class="cv-spec__info">
                            <span class="cv-spec__name">{c.nombre}</span>
                            <span class="cv-spec__inst">{c.institucion}{c.fecha ? ` · ${c.fecha}` : ''}</span>
                          </div>
                          {c.certificado && (
                            <a
                              href={c.externo ? c.certificado : c.certificado}
                              target="_blank"
                              rel="noopener"
                              class="cv-spec__cert-link"
                            >↗ cert</a>
                          )}
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    </main>

    <Footer />

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { registerPlugins } from '../lib/gsap-utils';

      registerPlugins();

      const cvHeroTitle = document.querySelector<HTMLElement>('.cv-name');
      const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Typewriter: no SplitText, no font wait, instant on all devices ──
      if (cvHeroTitle) {
        const fullText = cvHeroTitle.textContent?.trim() ?? '';

        if (reducedMotion) {
          // Show immediately, no animation
          cvHeroTitle.style.visibility = 'visible';
        } else {
          cvHeroTitle.textContent = '';
          cvHeroTitle.style.visibility = 'visible';

          let i = 0;
          const TYPE_SPEED = 22; // ms per character — fast but readable

          const type = () => {
            if (i < fullText.length) {
              cvHeroTitle.textContent += fullText[i++];
              setTimeout(type, TYPE_SPEED);
            } else {
              // Typing done — fade in label + buttons
              gsap.from('.cv-hero__label', { autoAlpha: 0, duration: 0.3, delay: 0.05 });
              gsap.from('.cv-actions a', { autoAlpha: 0, y: 14, stagger: 0.08, duration: 0.35, delay: 0.15 });
            }
          };
          type();
        }
      }

      // ── ScrollTrigger reveals — work on all devices ──
      if (!reducedMotion) {
        ScrollTrigger.batch('.cv-exp-item', {
          onEnter: els => gsap.from(els, {
            x: 20,
            autoAlpha: 0,
            stagger: 0.1,
            duration: 0.45,
          }),
          once: true,
          start: 'top 92%',
        });
      }

    </script>

    <style>
      .cv-term {
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        background: var(--bg-raised);
        box-shadow: 0 4px 24px rgba(0,0,0,.18);
      }
      .cv-term__bar {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 10px 14px;
        background: var(--bg-code, #1a1a1a);
        border-bottom: 1px solid var(--border);
      }
      .cv-term__dot {
        width: 12px; height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .cv-term__dot--red    { background: #ff5f57; }
      .cv-term__dot--yellow { background: #febc2e; }
      .cv-term__dot--green  { background: #28c840; }
      .cv-term__title {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-muted);
        margin-left: 6px;
      }
      .cv-term__body {
        padding: 16px 20px 20px;
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.7;
      }
      .cv-term__prompt {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
      }
      .cv-term__prompt--idle { margin-top: 8px; margin-bottom: 0; }
      .cv-term__ps1 { display: flex; align-items: center; gap: 0; white-space: nowrap; }
      .cv-term__user   { color: #28c840; }
      .cv-term__at     { color: var(--text-muted); }
      .cv-term__host   { color: #58a6ff; }
      .cv-term__sep    { color: var(--text-muted); }
      .cv-term__path   { color: #febc2e; }
      .cv-term__dollar { color: var(--text-muted); margin-left: 4px; margin-right: 4px; }
      .cv-term__cmd    { color: var(--text); }
      .cv-term__output { padding-left: 4px; margin-bottom: 2px; }
      .cv-term__line {
        display: grid;
        grid-template-columns: 90px 1fr;
        gap: 12px;
        padding: 2px 0;
      }
      .cv-term__line--accent .cv-term__val { color: #28c840; }
      .cv-term__key { color: #58a6ff; }
      .cv-term__val { color: var(--text); word-break: break-word; }
      .cv-term__cursor {
        display: inline-block;
        width: 8px; height: 15px;
        background: var(--accent, #58a6ff);
        opacity: 0.85;
        animation: blink 1.1s step-end infinite;
        vertical-align: text-bottom;
      }
      @keyframes blink {
        0%, 100% { opacity: 0.85; }
        50% { opacity: 0; }
      }

      .cv-hero { border-bottom: 1px dashed var(--border); }
      .cv-hero__inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 64px var(--pad-x) 56px;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 80px;
        align-items: start;
      }
      @media (max-width: 900px) {
        .cv-hero__inner { grid-template-columns: 1fr; gap: 40px; }
      }
      .cv-hero__label {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--accent);
        margin-bottom: 24px;
        letter-spacing: 0.02em;
      }
      .cv-name {
        font-family: var(--font-sans);
        font-size: clamp(40px, 6vw, 64px);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 1.02;
        color: var(--text-strong);
        margin: 0;
      }
      .cv-role {
        font-family: var(--font-mono);
        font-size: 15px;
        color: var(--text-muted);
        margin-top: 16px;
      }
      .cv-summary {
        font-family: var(--font-sans);
        font-size: 17px;
        line-height: 1.6;
        color: var(--text);
        max-width: 600px;
        margin: 28px 0 0;
      }
      .cv-actions { margin-top: 32px; display: flex; gap: 12px; flex-wrap: wrap; }
      .cv-btn {
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--text);
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--bg-raised);
        text-decoration: none;
      }
      .cv-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
      }

      .cv-section-head {
        display: flex;
        gap: 18px;
        align-items: baseline;
        padding-bottom: 24px;
        margin-bottom: 32px;
        border-bottom: 1px solid var(--border);
      }
      .cv-section-head--compact {
        padding-bottom: 16px;
        margin-bottom: 24px;
      }

      .cv-exp-list { display: flex; flex-direction: column; }
      .cv-exp-item {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 40px;
        padding: 28px 0;
        border-top: 1px solid var(--border-dim);
      }
      @media (max-width: 700px) {
        .cv-exp-item { grid-template-columns: 1fr; gap: 12px; }
      }
      .cv-exp__l { display: flex; flex-direction: column; gap: 6px; padding-top: 4px; }
      .cv-exp__period {
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--accent);
        font-weight: 500;
      }
      .cv-exp__cert {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
        text-decoration: none;
      }
      .cv-exp__role {
        font-family: var(--font-sans);
        font-size: 19px;
        color: var(--text-strong);
        font-weight: 700;
        letter-spacing: -0.01em;
        margin-bottom: 14px;
      }
      .cv-exp__at { color: var(--text-dim); margin: 0 8px; }
      .cv-exp__company { color: var(--text-muted); font-weight: 500; }
      .cv-exp__bullets { list-style: none; padding: 0; margin: 0; }
      .cv-exp__bullets li {
        font-family: var(--font-serif);
        font-size: 16px;
        line-height: 1.55;
        color: var(--text);
        padding: 5px 0;
        display: grid;
        grid-template-columns: 20px 1fr;
        gap: 8px;
        max-width: 720px;
      }
      .cv-exp__bullets strong { color: var(--text-strong); font-weight: 700; }
      .cv-exp__dash { color: var(--accent); }
      .cv-exp__stack { margin-top: 14px; display: flex; gap: 6px; flex-wrap: wrap; }
      .cv-exp__tag {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
        border: 1px solid var(--border);
        padding: 2px 8px;
        border-radius: 3px;
        background: var(--bg-raised);
      }

      .cv-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
      }
      @media (max-width: 900px) {
        .cv-two-col { grid-template-columns: 1fr; gap: 48px; }
      }

      .cv-edu { display: flex; flex-direction: column; gap: 20px; }
      .cv-edu-item {
        padding-bottom: 16px;
        border-bottom: 1px dashed var(--border-dim);
      }
      .cv-edu__title {
        font-family: var(--font-sans);
        font-size: 16px;
        color: var(--text-strong);
        font-weight: 600;
      }
      .cv-edu__place {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
      }
      .cv-edu__estado {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--accent);
        margin-top: 4px;
      }
      .cv-edu__cert {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
        text-decoration: none;
        margin-top: 4px;
        display: inline-block;
      }
      .cv-edu__cert:hover { color: var(--accent); }

      .cv-spec { display: flex; flex-direction: column; gap: 4px; }
      .cv-spec-item {
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--bg-raised);
        overflow: hidden;
      }
      .cv-spec-item summary {
        padding: 12px 16px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--text);
      }
      .cv-spec-item summary::marker { content: ""; }
      .cv-spec-item summary::-webkit-details-marker { display: none; }
      .cv-spec__cat { font-weight: 500; }
      .cv-spec__count { color: var(--text-muted); font-size: 12px; }
      .cv-spec__list {
        list-style: none;
        margin: 0;
        padding: 0 16px 12px;
        border-top: 1px dashed var(--border-dim);
      }
      .cv-spec__list li {
        padding: 8px 0;
        font-family: var(--font-mono);
        font-size: 12px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
      }
      .cv-spec__info { display: flex; flex-direction: column; gap: 2px; }
      .cv-spec__name { color: var(--text); }
      .cv-spec__inst { color: var(--text-muted); font-size: 11px; }
      .cv-spec__cert-link {
        font-size: 11px;
        color: var(--text-muted);
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
        padding-top: 1px;
      }
      .cv-spec__cert-link:hover { color: var(--accent); }

      .cv-proj-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
      }

      /* ── Flip card ── */
      .cv-proj-item {
        perspective: 900px;
        height: 220px;
      }
      .cv-proj__inner {
        position: relative;
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
        transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .cv-proj-item:hover .cv-proj__inner,
      .cv-proj-item:focus-within .cv-proj__inner {
        transform: rotateY(180deg);
      }
      @media (prefers-reduced-motion: reduce) {
        .cv-proj__inner { transition: none; }
      }
      .cv-proj__front,
      .cv-proj__back {
        position: absolute;
        inset: 0;
        border-radius: 6px;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
      }

      /* Front face */
      .cv-proj__front {
        border: 1px solid var(--border);
        background: var(--bg-raised);
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .cv-proj__header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
      }
      .cv-proj__title {
        font-family: var(--font-sans);
        font-size: 16px;
        font-weight: 700;
        color: var(--text-strong);
      }
      .cv-proj__co {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
      }
      .cv-proj__desc {
        font-family: var(--font-serif);
        font-size: 15px;
        line-height: 1.55;
        color: var(--text);
        margin: 0;
      }
      .cv-proj__link {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
        text-decoration: none;
        margin-top: auto;
      }
      .cv-proj__link:hover { color: var(--accent); }

      /* Back face */
      .cv-proj__back {
        transform: rotateY(180deg);
        overflow: hidden;
